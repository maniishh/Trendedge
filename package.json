{
  "name": "trendedge",
  "version": "2.0.0",
  "description": "Professional stock analytics dashboard",
  "main": "server/index.js",
  "scripts": {
    "start":       "node server/index.js",
    "dev":         "nodemon server/index.js",
    "dev:client":  "npm run dev --prefix client",
    "dev:full":    "concurrently \"npm run dev\" \"npm run dev:client\"",
    "install:all": "npm install && npm install --prefix client",
    "build":       "npm run build --prefix client"
  },
  "dependencies": {
    "axios":              "^1.10.0",
    "bcryptjs":           "^3.0.2",
    "cookie-parser":      "^1.4.6",
    "cors":               "^2.8.5",
    "dotenv":             "^17.0.0",
    "express":            "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "express-validator":  "^7.2.1",
    "helmet":             "^8.0.0",
    "jsonwebtoken":       "^9.0.2",
    "mongoose":           "^8.16.1",
    "morgan":             "^1.10.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon":      "^3.1.9"
  }
}
